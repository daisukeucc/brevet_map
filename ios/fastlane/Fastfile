# frozen_string_literal: true

default_platform(:ios)

# ios/fastlane から見た Flutter プロジェクトルート
def project_root
  File.expand_path("../..", __dir__)
end

# CI では bundle exec 後に PATH から flutter が消えることがあるため FLUTTER_ROOT を優先する
def flutter_executable
  root = ENV["FLUTTER_ROOT"]
  if root && !root.empty?
    candidate = File.join(root, "bin", "flutter")
    return candidate if File.exist?(candidate)
  end
  "flutter"
end

# App Store Connect API:
# - 分割: APP_STORE_CONNECT_KEY_ID / ISSUER_ID / KEY_CONTENT(base64)
# - または 1 本: APP_STORE_CONNECT_API_KEY に JSON
#   {"key_id":"...","issuer_id":"...","key":"<p8 を base64>"}
def asc_api_key
  require "json"
  if ENV["APP_STORE_CONNECT_KEY_ID"] && !ENV["APP_STORE_CONNECT_KEY_ID"].to_s.empty?
    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_KEY_CONTENT"),
      is_key_content_base64: true
    )
  elsif ENV["APP_STORE_CONNECT_API_KEY"] && !ENV["APP_STORE_CONNECT_API_KEY"].to_s.empty?
    data = JSON.parse(ENV.fetch("APP_STORE_CONNECT_API_KEY"))
    key_is_base64 = data.fetch("key_is_base64", true)
    app_store_connect_api_key(
      key_id: data.fetch("key_id"),
      issuer_id: data.fetch("issuer_id"),
      key_content: data.fetch("key"),
      is_key_content_base64: key_is_base64
    )
  else
    UI.user_error!("App Store Connect: 環境変数 APP_STORE_CONNECT_KEY_ID 等、または APP_STORE_CONNECT_API_KEY(JSON) を設定してください。")
  end
end

platform :ios do
  desc "Flutter でリリース用 IPA をビルド（署名は Xcode / CI のプロファイルに依存）"
  desc "CI: EXPORT_OPTIONS_PLIST_PATH に ExportOptions（manual・Runner+Extension）を渡す"
  lane :build_ipa do
    Dir.chdir(project_root) do
      flutter_bin = flutter_executable
      sh(flutter_bin, "pub", "get")
      raw = ENV["EXPORT_OPTIONS_PLIST_PATH"]
      export_plist =
        if raw && !raw.to_s.empty?
          File.expand_path(raw, project_root)
        end
      if export_plist && File.exist?(export_plist)
        sh(flutter_bin, "build", "ipa", "--release", "--export-options-plist=#{export_plist}")
      else
        sh(flutter_bin, "build", "ipa", "--release")
      end
    end
  end

  desc "既存の IPA を TestFlight にアップロード（App Store Connect API キー必須）"
  lane :upload_testflight do
    ipa_path = ENV["IPA_PATH"] || Dir.glob(File.join(project_root, "build/ios/ipa/*.ipa")).max_by { |p| File.mtime(p) }
    UI.user_error!("IPA が見つかりません。先に build_ipa するか IPA_PATH を指定してください。") if ipa_path.nil? || !File.exist?(ipa_path)

    api_key = asc_api_key

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true
    )
  end

  desc "build_ipa のあと TestFlight へアップロード"
  lane :beta do
    build_ipa
    upload_testflight
  end
end
